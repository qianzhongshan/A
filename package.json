{
  "name": "mbti-deep-test",
  "version": "1.0.0",
  "description": "MBTI 93题论述版深度测试系统",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && python -m uvicorn app:app --reload --host 0.0.0.0 --port 8000",
    "dev:frontend": "cd frontend && npm run dev",
    "install:all": "npm install && cd backend && pip install -r requirements.txt && cd ../frontend && npm install",
    "build": "cd frontend && npm run build",
    "deploy": "vercel --prod"
  },
  "keywords": ["mbti", "personality", "test", "deepseek", "vue", "fastapi"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
